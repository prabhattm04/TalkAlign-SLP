PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase — find these in your project dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Azure OpenAI — for SOAP note generation and parent summaries
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Sarvam AI — for Indian language speech-to-text (Hinglish / Saaras v3)
# Get your key at: https://dashboard.sarvam.ai/
SARVAM_API_KEY=your-sarvam-api-key-here
